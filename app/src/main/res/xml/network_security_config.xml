<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!-- block all cleartext HTTP — forces HTTPS for every connection -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Gemini API is HTTPS only so no exemptions needed -->

</network-security-config>